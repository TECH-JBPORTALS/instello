{
	"name": "@instello/transactional",
	"version": "0.1.0",
	"private": true,
	"exports": {
		"./emails/*": "./emails/*.tsx"
	},
	"scripts": {
		"build": "email build",
		"dev": "email dev --port 3001",
		"export": "email export",
		"clean": "rm -rf node_modules .turbo dist cache",
		"check": "biome check",
		"fix": "biome check --write",
		"fix:unsafe": "biome check --write --unsafe",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"react-email": "6.8.1",
		"react-dom": "19.2.4",
		"react": "19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@react-email/ui": "6.8.1",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"typescript": "catalog:"
	}
}
