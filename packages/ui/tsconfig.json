{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ES2021", "dom"],
		"moduleResolution": "bundler",
		"module": "preserve",
		"resolvePackageJsonImports": true,
		"jsx": "react-jsx",
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"paths": {
			"@/*": ["./*"]
		}
	}
}
