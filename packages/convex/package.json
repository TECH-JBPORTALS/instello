{
	"name": "@instello/convex",
	"version": "0.1.0",
	"description": "",
	"exports": {
		"./api": {
			"types": "./src/functions/_generated/api.d.ts",
			"default": "./src/functions/_generated/api.js"
		},
		"./dataModel": {
			"types": "./src/functions/_generated/dataModel.d.ts"
		},
		"./better-auth/client": "./src/better-auth/client.ts",
		"./better-auth/server": "./src/better-auth/server.ts",
		"./better-auth/provider": "./src/better-auth/provider.tsx",
		"./better-auth/schema": "./src/better-auth/schema.ts",
		"./errors": {
			"types": "./src/functions/helpers/constants.ts",
			"default": "./src/functions/helpers/constants.ts"
		},
		"./constants": {
			"types": "./src/functions/helpers/constants.ts",
			"default": "./src/functions/helpers/constants.ts"
		},
		"./schedule": {
			"types": "./src/functions/helpers/timetableSchedule.ts",
			"default": "./src/functions/helpers/timetableSchedule.ts"
		}
	},
	"imports": {
		"#*": {
			"types": "./src/functions/*.d.ts",
			"import": "./src/functions/*.js",
			"default": "./src/functions/*.ts"
		}
	},
	"scripts": {
		"dev": "convex dev",
		"setup": "convex dev --until-success",
		"typecheck": "tsc --noEmit",
		"check": "biome check",
		"fix": "biome check --write",
		"fix:unsafe": "biome check --write --unsafe",
		"test": "vitest run",
		"test:watch": "vitest",
		"auth:generate": "bunx auth generate --config src/functions/betterAuth/auth.ts --output src/functions/betterAuth/authSchema.ts",
		"clean": "rm -rf .turbo dist node_modules"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@convex-dev/better-auth": "^0.12.4",
		"better-auth": "~1.6.15",
		"convex": "catalog:",
		"convex-helpers": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@edge-runtime/vm": "^5.0.0",
		"@faker-js/faker": "^10.5.0",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"convex-test": "^0.0.53",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
