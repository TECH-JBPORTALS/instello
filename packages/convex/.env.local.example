# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:modest-peacock-357 # team: manoj, project: instello

CONVEX_URL=https://modest-peacock-357.eu-west-1.convex.cloud

CONVEX_SITE_URL=https://modest-peacock-357.eu-west-1.convex.site

# Set the better-auth secret and site url once the convex is deployed, run below commands inside the packages/convex folder through command prompt
# 1. bun x convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
# 2. bun x convex env set SITE_URL http://localhost:3000