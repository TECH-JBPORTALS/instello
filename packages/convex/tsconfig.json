{
	"compilerOptions": {
		"allowJs": true,
		"strict": true,
		"target": "ESNext",
		"lib": ["ESNext", "dom"],
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"jsx": "preserve",
		"types": ["node", "vitest/globals", "vite/client"]
	},
	"include": ["src/**/*", "convex-dev.d.ts"],
	"exclude": ["**/_generated/**/*", "node_modules"]
}
