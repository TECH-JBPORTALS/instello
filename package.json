{
	"name": "instello",
	"private": true,
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"test": "turbo run test",
		"test:backend": "turbo run --filter=@instello/backend test",
		"typecheck": "turbo run typecheck",
		"clean": "turbo run clean && rm -rf node_modules",
		"check": "turbo run check",
		"fix": "turbo run fix",
		"fix:unsafe": "turbo run fix:unsafe"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/bun": "^1.3.14",
		"bun": "^1.3.14",
		"turbo": "^2.9.16"
	},
	"engines": {
		"node": ">=20.20.0"
	},
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@biomejs/biome": "2.4.16",
			"@tabler/icons-react": "^3.44.0",
			"react": "^19.2.5",
			"react-dom": "^19.2.5",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"typescript": "6.0.3",
			"tailwindcss": "4.2.4",
			"vite": "^8.0.16",
			"vitest": "^4.1.8"
		}
	},
	"packageManager": "bun@1.2.2",
	"dependencies": {
		"clsx": "^2.1.1",
		"convex-helpers": "^0.1.119",
		"convex-test": "^0.0.53"
	}
}
