{
	"$schema": "https://v2-9-16.turborepo.dev/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"ui": "tui",
	"tasks": {
		"build": {
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"],
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {},
		"check": {},
		"fix": {},
		"fix:unsafe": {},
		"typecheck": {},
		"clean": {
			"cache": false
		}
	},
	"globalEnv": [
		"NODE_ENV",
		"CONVEX_DEPLOY_KEY",
		"NEXT_PUBLIC_CONVEX_URL",
		"NEXT_PUBLIC_CONVEX_SITE_URL",
		"NEXT_PUBLIC_ROOT_DOMAIN",
		"CONVEX_URL",
		"CONVEX_DEPLOYMENT",
		"CONVEX_SITE_URL"
	]
}
